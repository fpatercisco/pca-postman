{
  "info": {
    "_postman_id": "28b014a3-4971-4f97-b510-9e5c9dfc26b5",
    "name": "PCA Analytics",
    "description": "You must set `tenant-url` somewhere to use this collection.\n\nFor airgapped and on-prem, you must also set `token`, as the Login call doesn't work for these install types. See [https://docs.crossworkassurance.cisco.com/25-7/docs/obtain-a-personal-access-token](https://docs.crossworkassurance.cisco.com/25-7/docs/obtain-a-personal-access-token).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "27734625"
  },
  "item": [
    {
      "name": "Login (cloud tenants only)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.environment.set(\"token\", pm.response.headers.get('Authorization'));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cache-Control",
            "value": "no-cache",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded",
            "type": "text"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "{{username}}",
              "type": "text"
            },
            {
              "key": "password",
              "value": "{{password}}",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{tenant-url}}/api/v1/auth/login",
          "host": [
            "{{tenant-url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        },
        "description": "See [https://docs.crossworkassurance.cisco.com/25-7/docs/obtain-a-personal-access-token](https://docs.crossworkassurance.cisco.com/25-7/docs/obtain-a-personal-access-token) for on-prem/airgapped tenants."
      },
      "response": []
    },
    {
      "name": "Retrieve all connectors (Sensor Collectors aka Roadrunners)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{tenant-url}}/api/v3/connectors",
          "host": [
            "{{tenant-url}}"
          ],
          "path": [
            "api",
            "v3",
            "connectors"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Retrieve all connector configs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{tenant-url}}/api/v2/connector-configs",
          "host": [
            "{{tenant-url}}"
          ],
          "path": [
            "api",
            "v2",
            "connector-configs"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Retrieve all ingestion dictionaries (\"data dictionaries\") (includes custom calculations)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{tenant-url}}/api/v3/ingestion-dictionaries",
          "host": [
            "{{tenant-url}}"
          ],
          "path": [
            "api",
            "v3",
            "ingestion-dictionaries"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Retrieve all agents (includes telemetry collectors)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{tenant-url}}/api/orchestrate/v3/agents",
          "host": [
            "{{tenant-url}}"
          ],
          "path": [
            "api",
            "orchestrate",
            "v3",
            "agents"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Retrieve all agent configurations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "https://{{tenant-url}}/api/orchestrate/v3/agents/configuration",
          "protocol": "https",
          "host": [
            "{{tenant-url}}"
          ],
          "path": [
            "api",
            "orchestrate",
            "v3",
            "agents",
            "configuration"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Retrieve all monitored objects (\"Sessions\" in the UI)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{tenant-url}}/api/v2/monitored-objects",
          "host": [
            "{{tenant-url}}"
          ],
          "path": [
            "api",
            "v2",
            "monitored-objects"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "tenant-url",
      "value": "",
      "type": "string"
    },
    {
      "key": "username",
      "value": "",
      "type": "string"
    },
    {
      "key": "password",
      "value": "",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
